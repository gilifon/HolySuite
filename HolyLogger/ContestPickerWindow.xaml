<Window x:Class="HolyLogger.ContestPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select contest" Height="560" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#EEF2F7">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Choose a contest to enter contest mode" FontSize="16" FontWeight="Bold" Foreground="#1565C0"/>
            <TextBlock Text="Only contests ready for logging are selectable. Others appear greyed until they're added."
                       FontSize="12" Foreground="#666666" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#1565C0" BorderThickness="1" Background="White">
            <ListBox x:Name="LB_Contests" BorderThickness="0"
                     SelectionChanged="LB_Contests_SelectionChanged"
                     MouseDoubleClick="LB_Contests_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="6,5" Opacity="{Binding RowOpacity}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="#1565C0"/>
                                    <TextBlock Text="{Binding StatusTag}" FontSize="11" Foreground="#BB3300"
                                               Margin="8,2,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Sub}" FontSize="11.5" Foreground="#666666"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <Button x:Name="Btn_Exit" Content="Exit contest" DockPanel.Dock="Left"
                    Padding="12,6" Click="Btn_Exit_Click"
                    FontSize="16" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="Btn_Cancel" Content="Cancel" Padding="14,6" Margin="0,0,8,0" Click="Btn_Cancel_Click"
                        FontSize="16"/>
                <Button x:Name="Btn_Activate" Content="Activate" Padding="18,6" FontWeight="Bold"
                        FontSize="16" IsEnabled="False" Click="Btn_Activate_Click"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
