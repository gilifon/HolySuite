<Window x:Class="HolyLogger.LotwConfirmQueueDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset LoTW Queue"
        Width="500" Height="310"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="56"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Question mark icon -->
        <Ellipse Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                 Width="44" Height="44" Fill="#1565C0"
                 VerticalAlignment="Top" HorizontalAlignment="Left"/>
        <TextBlock Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                   Text="?" FontSize="28" FontWeight="Bold" Foreground="White"
                   HorizontalAlignment="Left" VerticalAlignment="Top"
                   Width="44" Height="44" TextAlignment="Center"
                   Padding="0,2,0,0"/>

        <!-- Main question -->
        <TextBlock Grid.Row="0" Grid.Column="1"
                   FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap">
            <Run Text="Mark QSOs from "/>
            <Run x:Name="DateRun" FontWeight="Bold" Foreground="#1565C0"/>
            <Run Text=" onwards as pending for LoTW upload?"/>
        </TextBlock>

        <!-- QSO count badge -->
        <Border Grid.Row="2" Grid.Column="1"
                Background="#E3F2FD" BorderBrush="#1565C0" BorderThickness="1"
                CornerRadius="5" Padding="14,8" HorizontalAlignment="Left">
            <TextBlock FontSize="18">
                <Run x:Name="CountRun" FontWeight="Bold" Foreground="#1565C0"/>
                <Run Text=" QSOs will be added to the upload queue." Foreground="#1565C0"/>
            </TextBlock>
        </Border>

        <!-- Sub note -->
        <TextBlock Grid.Row="4" Grid.Column="1"
                   Text="LoTW will automatically skip any QSOs already in the system."
                   FontSize="14" Foreground="#666666" TextWrapping="Wrap"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="YesBtn" Content="Yes" Width="100" Height="38"
                    FontSize="17" IsDefault="True" Margin="0,0,12,0"
                    Click="YesBtn_Click"/>
            <Button x:Name="NoBtn" Content="No" Width="100" Height="38"
                    FontSize="17" IsCancel="True"
                    Click="NoBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
