<Window

    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit" 
        xmlns:xcdg="http://schemas.xceed.com/wpf/xaml/datagrid"
        xmlns:local="clr-namespace:HolyLogger"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:ToolsUserControls="clr-namespace:HolyLogger.ToolsUserControls"
        x:Class="HolyLogger.MainWindow"
        Title="HolyLogger" 
        WindowStartupLocation="Manual"
        MinHeight="560" MinWidth="800" 
        Icon="Images/crown.png" 
        KeyDown="Window_KeyDown" Closing="Window_Closing" Closed="Window_Closed" Loaded="Window_Loaded" SourceInitialized="Window_SourceInitialized" LocationChanged="Window_LocationChanged" SizeChanged="Window_SizeChanged">

    <Window.Resources>
        <local:QsoDateDisplayConverter x:Key="QsoDateDisplayConverter"/>
        <local:QsoTimeDisplayConverter x:Key="QsoTimeDisplayConverter"/>
        <local:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
        <Style x:Key="RaisedActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#1E2A34"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#7A95A8"/>
            <Setter Property="Background" Value="#E8F2FA"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="4"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#F7FBFF" Offset="0"/>
                                    <GradientStop Color="#DCEAF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.35" Color="#6A8296"/>
                            </Border.Effect>
                            <ContentPresenter x:Name="ContentHost"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#1F5C8E"/>
                                <Setter TargetName="ButtonBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#4D9AD8" Offset="0"/>
                                            <GradientStop Color="#2E76B4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#486A86"/>
                                <Setter TargetName="ButtonBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#C9DCEF" Offset="0"/>
                                            <GradientStop Color="#B5CEE5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ButtonBorder" Property="Effect" Value="{x:Null}"/>
                                <Setter TargetName="ContentHost" Property="Margin" Value="0,1,0,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                                <Setter Property="Foreground" Value="#8797A4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E6CCFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RoundedButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#9966CC"
                                BorderThickness="1"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RoundedButtonBorder" Property="Background" Value="#CFA6FF"/>
                                <Setter TargetName="RoundedButtonBorder" Property="BorderBrush" Value="#7A33CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RoundedButtonBorder" Property="Background" Value="#B980F5"/>
                                <Setter TargetName="RoundedButtonBorder" Property="BorderBrush" Value="#5E1FA8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RoundedButtonBorder" Property="Background" Value="#E4E4E4"/>
                                <Setter TargetName="RoundedButtonBorder" Property="BorderBrush" Value="#B5B5B5"/>
                                <Setter Property="Foreground" Value="#7A7A7A"/>
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Msg button style: same keyboard-key shape as cluster band filter buttons, purple when CAT OK / gray when disabled -->
        <Style x:Key="MsgButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E6CCFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- Outer border: darker bottom edge like a physical key -->
                        <Border x:Name="KeyOuter" CornerRadius="5" Background="#7A33CC" SnapsToDevicePixels="True" Padding="0,0,0,3">
                            <!-- Inner face with gradient -->
                            <Border x:Name="KeyFace" CornerRadius="5" BorderThickness="1" BorderBrush="#9966CC" SnapsToDevicePixels="True" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,2,4,2"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="KeyOuter" Property="Background" Value="#5E1FA8"/>
                                <Setter TargetName="KeyFace" Property="Background" Value="#CFA6FF"/>
                                <Setter TargetName="KeyFace" Property="BorderBrush" Value="#7A33CC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="KeyFace" Property="Margin" Value="0,2,0,0"/>
                                <Setter TargetName="KeyOuter" Property="Padding" Value="0,2,0,1"/>
                                <Setter TargetName="KeyFace" Property="Background" Value="#B980F5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="KeyOuter" Property="Background" Value="#888888"/>
                                <Setter TargetName="KeyFace" Property="Background" Value="#E4E4E4"/>
                                <Setter TargetName="KeyFace" Property="BorderBrush" Value="#B5B5B5"/>
                                <Setter Property="Foreground" Value="#7A7A7A"/>
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Msg button style for CW mode: cyan keyboard-key shape with 3D effect, matching SSB style -->
        <Style x:Key="MsgButtonCwStyle" TargetType="Button">
            <Setter Property="Background" Value="#7FFEFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- Outer border: darker bottom edge like a physical key -->
                        <Border x:Name="KeyOuter" CornerRadius="5" Background="#0099CC" SnapsToDevicePixels="True" Padding="0,0,0,3">
                            <!-- Inner face -->
                            <Border x:Name="KeyFace" CornerRadius="5" BorderThickness="1" BorderBrush="#00CCFF" SnapsToDevicePixels="True" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,2,4,2"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="KeyOuter" Property="Background" Value="#005C80"/>
                                <Setter TargetName="KeyFace" Property="Background" Value="#33C2D6"/>
                                <Setter TargetName="KeyFace" Property="BorderBrush" Value="#0077AA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="KeyFace" Property="Margin" Value="0,2,0,0"/>
                                <Setter TargetName="KeyOuter" Property="Padding" Value="0,2,0,1"/>
                                <Setter TargetName="KeyFace" Property="Background" Value="#1FA6BC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="KeyOuter" Property="Background" Value="#888888"/>
                                <Setter TargetName="KeyFace" Property="Background" Value="#E4E4E4"/>
                                <Setter TargetName="KeyFace" Property="BorderBrush" Value="#B5B5B5"/>
                                <Setter Property="Foreground" Value="#7A7A7A"/>
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Action button style: same keyboard-key shape, light blue for Add/Clear -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#CCE8FF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="KeyOuter" CornerRadius="5" Background="#3A80C8" SnapsToDevicePixels="True" Padding="0,0,0,3">
                            <Border x:Name="KeyFace" CornerRadius="5" BorderThickness="1" BorderBrush="#5599DD" SnapsToDevicePixels="True" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,2,4,2"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="KeyOuter" Property="Background" Value="#1F5C8E"/>
                                <Setter TargetName="KeyFace" Property="Background" Value="#A8D8FF"/>
                                <Setter TargetName="KeyFace" Property="BorderBrush" Value="#3A80C8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="KeyFace" Property="Margin" Value="0,2,0,0"/>
                                <Setter TargetName="KeyOuter" Property="Padding" Value="0,2,0,1"/>
                                <Setter TargetName="KeyFace" Property="Background" Value="#7DC0F5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="KeyOuter" Property="Background" Value="#888888"/>
                                <Setter TargetName="KeyFace" Property="Background" Value="#E4E4E4"/>
                                <Setter TargetName="KeyFace" Property="BorderBrush" Value="#B5B5B5"/>
                                <Setter Property="Foreground" Value="#7A7A7A"/>
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SpotButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#1E2A34"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="KeyOuter" CornerRadius="5" Background="#C9A800" SnapsToDevicePixels="True">
                            <Border x:Name="KeyFace" CornerRadius="4,4,3,3" BorderThickness="1" BorderBrush="#E0C94A" Margin="0,0,0,3" SnapsToDevicePixels="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFF9C4" Offset="0"/>
                                        <GradientStop Color="#FFEB3B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="KeyFace" Property="BorderBrush" Value="#1F5C8E"/>
                                <Setter TargetName="KeyOuter" Property="Background" Value="#1860B0"/>
                                <Setter TargetName="KeyFace" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#4D9AD8" Offset="0"/>
                                            <GradientStop Color="#2E76B4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="KeyFace" Property="Margin" Value="0,2,0,1"/>
                                <Setter TargetName="KeyOuter" Property="Background" Value="#666666"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="KeyOuter" Property="Opacity" Value="0.55"/>
                                <Setter Property="Foreground" Value="#8797A4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="AddLogGrid" ShowGridLines="false" Margin="2,0,-2,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition x:Name="MainForm" Height="325" />
            <RowDefinition Height="*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <DockPanel x:Name="MainScreen" Grid.Row="0">
            <Menu DockPanel.Dock="Top">
                <MenuItem Header="File" FontSize="16">
                    <MenuItem x:Name="ImportMenuItem" Header="Import ADIF" ToolTip="Generates log from ADIF" Click="ImportAdifMenuItem_Click" >
                        <MenuItem.Icon>
                            <Image Source="Images/import.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem x:Name="ExportMenuItem" Header="Export ADIF" ToolTip="Generates ADIF file from the QSO list" Click="ExportMenuItem_Click" >
                        <MenuItem.Icon>
                            <Image Source="Images/exportA.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ExportCabrilloMenuItem" Header="Export Cabrillo" ToolTip="Generates Cabrillo file from the QSO list" Click="ExportCabrilloMenuItem_Click" >
                        <MenuItem.Icon>
                            <Image Source="Images/exportC.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ExpotExlMenuItem" Header="Export CSV" ToolTip="Generates CSV file from the QSO list" Click="ExpotCSVMenuItem_Click" >
                        <MenuItem.Icon>
                            <Image Source="Images/exportX.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem x:Name="UploadMenuItem" Header="Send log" ToolTip="Sends the log to the contest manager" Click="UploadMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/upload_log.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="StatisticsMenuItem" Header="Statistics" ToolTip="Show QSO Statistics" Visibility="Collapsed">
                        <MenuItem.Icon>
                            <Image Source="Images/statistics.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <!--<MenuItem x:Name="OpenFolderItem" Header="Open application directory" Click="OpenFolderItem_Click" ToolTip="Open the upload report folder">
                                <MenuItem.Icon>
                                    <Image Source="Images/folder.png" Stretch="UniformToFill" Width="16" Height="16"/>
                                </MenuItem.Icon>
                            </MenuItem>-->
                    <MenuItem x:Name="ExitMenuItem" Header="Exit" Click="ExitMenuItem_Click" ToolTip="Close the program">
                        <MenuItem.Icon>
                            <Image Source="Images/exit.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="View" FontSize="16">
                    <MenuItem x:Name="SignboardMenuItem" Header="Signboard" ToolTip="Open a Signboard with your callsign and square" Click="SignboardMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/sign.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="TimerItem" Header="Timer" ToolTip="Open a 1 hour countdown timer" Click="TimerMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/timer.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MatrixMenuItem" Header="Matrix" ToolTip="Open a matrix presentation for the DX station" Click="MatrixMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/matrix.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ClusterMenuItem" Header="Cluster" ToolTip="Open cluster window" Click="ClusterMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/onair.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <!--<MenuItem x:Name="LogInfoMenuItem" Header="Statistics" ToolTip="Show some log statistics" Click="LogInfoMenuItem_Click">
                                <MenuItem.Icon>
                                    <Image Source="Images/chart.png" Stretch="UniformToFill" Width="16" Height="16"/>
                                </MenuItem.Icon>
                            </MenuItem>-->
                </MenuItem>
                <MenuItem Header="Tools" FontSize="16" SubmenuOpened="ToolsMenu_SubmenuOpened">
                    <!--<MenuItem x:Name="MyStationMenuItem" Header="My Station" ToolTip="Set your station info">
                                <MenuItem.Icon>
                                    <Image Source="Images/station.png" Stretch="UniformToFill" Width="16" Height="16"/>
                                </MenuItem.Icon>
                            </MenuItem>-->
                    <MenuItem x:Name="ClearLogMenuItem" Header="Clear Log" ToolTip="Clear Log" Click="ClearLogMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/eraser.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ManualModeMenuItem" Header="Manual Mode" ToolTip="Manual Frequency and Time" Click="ManualModeMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/manual.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ContestModeMenuItem" Header="Contest Mode - OFF" Click="ContestModeMenuItem_Click" ToolTip="When ON, a same band+mode QSO is flagged as a Duplicate. When OFF, the program only shows how many times the station was worked before.">
                        <MenuItem.Icon>
                            <!-- The negative margin lets the blue tile grow beyond the fixed icon slot
                                 symmetrically, so it gets bigger without moving from its aligned spot. -->
                            <Border x:Name="ContestTrophyBg" Width="22" Height="22" CornerRadius="4" Background="Transparent"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-3">
                                <Viewbox Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path x:Name="ContestTrophyPath" Stretch="Uniform" Width="24" Height="24"
                                          Data="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"
                                          Fill="#9E9E9E"/>
                                </Viewbox>
                            </Border>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="ResetQSOCounterMenuItem" Header="Reset QSO Counter" ToolTip="Reset the QSO counter" Click="ResetRecentQSOCounterMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/gauge.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="EntireLogQrzServiseMenuItem" Header="Full-Log QRZ Service" ToolTip="Try to get QRZ info for the entire log" Click="EntireLogQrzServiseMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/qrz.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="RemoveDuplicatesMenuItem" Header="Remove Duplicates" ToolTip="Remove duplicates from the log" Click="RemoveDuplicatesMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/duplicate.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="SendQueueToEqslMenuItem" Header="Send Queue To eQSL" ToolTip="Upload the QSOs that are still waiting to be sent to eQSL.cc" Click="SendQueueToEqslMenuItem_Click" IsEnabled="False">
                        <MenuItem.Icon>
                            <!-- Same red "!" badge as the one on the log table, so the user instantly
                                 links this menu item to the alert they saw there. -->
                            <Border x:Name="SendQueueBadgeIcon" Width="16" Height="16" CornerRadius="8" Background="#9E9E9E" BorderBrush="White" BorderThickness="1">
                                <TextBlock Text="!" Foreground="White" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem x:Name="OptionsMenuItem" Header="Options (F2)" ToolTip="Customize your Holylogger" Click="OptionsMenuItemMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/properties.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Help" FontSize="16">
                    <MenuItem x:Name="UpdatesMenuItem" Header="Check for updates" ToolTip="Check for updates" Click="UpdatesMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/update.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem x:Name="HolyLogWebsiteMenuItem" Header="HolyLogger web page" ToolTip="Go to HolyLogger website" Click="HolyLoggerMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/crown.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="OmnirigMenuItem" Header="Omni-Rig web page" ToolTip="Go to Omni-Rig website" Click="OmnirigMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/OmniRigIcon.gif" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="GridSquareItem" Header="Grid / Square Map" ToolTip="Find your Grid / Square" Click="GridSquareMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/pin.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="OnTheAir" Header="HolyLogger On The Air" ToolTip="A cluster of HolyLogger user that are currently on the air" Click="OnTheAirMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/onair.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem x:Name="AboutMenuItem" Header="About" ToolTip="Some semi-important info.." Click="AboutMenuItem_Click">
                        <MenuItem.Icon>
                            <Image Source="Images/about.png" Stretch="UniformToFill" Width="16" Height="16"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
            </Menu>
        </DockPanel>
        <DockPanel Grid.Row="4">
            <StatusBar DockPanel.Dock="Bottom" MouseDoubleClick="StatusBar_MouseDoubleClick">
                <StatusBarItem x:Name="NetworkFlagItem">
                    <Ellipse x:Name="NetworkFlag" Margin="5,0,0,0" Fill="#00FF00" Height="16" Stroke="Black" Width="16" Visibility="Visible" ToolTip="Network conectivity" />
                </StatusBarItem>
                <StatusBarItem>
                    <TextBlock x:Name="L_QSO_Label" Text="QSOs: " Margin="10,0,0,0" FontSize="16"/>
                </StatusBarItem>
                <StatusBarItem>
                    <TextBlock x:Name="L_numOfQSO" Text="{Binding NumOfQSOs, RelativeSource={RelativeSource AncestorType={x:Type Window}, Mode=FindAncestor}}"  Margin="0,0,0,0" FontSize="16"/>
                </StatusBarItem>
                <StatusBarItem>
                    <TextBlock Text="Grids: " Margin="20,0,0,0" FontSize="16"/>
