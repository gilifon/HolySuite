                      Data="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-4v-3.1c1.63-.33 2.98-1.46 3.61-2.96C19.08 12.63 21 10.55 21 8V7c0-1.1-.9-2-2-2zM5 8V7h2v3.82C5.84 10.4 5 9.3 5 8zm14 0c0 1.3-.84 2.4-2 2.82V7h2v1z"
                      Fill="#9E9E9E"/>
            </Viewbox>
        </Border>
        <Label x:Name="L_Date" Content="Date" HorizontalAlignment="Left" Margin="353,97,0,0" VerticalAlignment="Top" Grid.Row="1" FontSize="16" ToolTip="The QSO's date"/>
        <xctk:DateTimeUpDown x:Name="TP_Date" Format="Custom" FormatString="dd-MM-yyyy" HorizontalAlignment="Left" TextAlignment="Left" Margin="398,100,0,0" Grid.Row="1" VerticalAlignment="Top" Width="112" FontSize="16" Height="28" IsTabStop="False" />
        <Label Content="Time" HorizontalAlignment="Left" Margin="516,97,0,0" VerticalAlignment="Top" Grid.Row="1" FontSize="16" ToolTip="The QSO's time"/>
        <xctk:DateTimeUpDown x:Name="TP_Time" Format="Custom" FormatString="HH:mm" HorizontalAlignment="Left" TextAlignment="Left" Margin="561,100,0,0" Grid.Row="1" VerticalAlignment="Top" Width="64" FontSize="16" Height="28" IsTabStop="False" />


        <Border BorderBrush="Gray" BorderThickness="1" HorizontalAlignment="Left" Height="1" Margin="10,92,0,0" VerticalAlignment="Top" Width="707" Grid.Row="1" />
        <Button x:Name="AddBtn" Style="{StaticResource ActionButtonStyle}" Content="Add (F1)" HorizontalAlignment="Left" Margin="634,143,0,0" VerticalAlignment="Top" Width="95" Height="32" Grid.Row="1" Click="AddBtn_Click" FontSize="15" ToolTip="Save the current QSO data" TabIndex="14" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0" />
        <Button x:Name="ClearBtn" Style="{StaticResource ActionButtonStyle}" HorizontalAlignment="Left" Margin="634,98,0,0" VerticalAlignment="Top" Width="95" Height="32" Grid.Row="1" Click="ClearBtn_Click" FontSize="15" ToolTip="Clear the current QSO data" IsTabStop="False" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Clear (F9)" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
        <!-- Undo icon for log-row "Set Radio to Freq" (independent of the cluster undo). Hidden when nothing to undo. -->
        <!-- Centered vertically between the Exchange (y=141) and Name (y=185) labels; horizontally centered to the Name label. -->
        <Grid x:Name="MainUndoIconGrid" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,164,0,0" Width="26" Height="26" Visibility="Collapsed" Panel.ZIndex="30">
            <Button x:Name="MainUndoButton" Width="26" Height="26" Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="0" Click="LogRadioUndoButton_Click" ToolTip="Undo radio frequency/mode change">
                <Grid>
                    <Image Source="Images/UNDO_Icon.png" Width="22" Height="22" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock x:Name="MainUndoCountText" FontSize="10" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                </Grid>
            </Button>
        </Grid>
        <Label Content="Name" HorizontalAlignment="Left" Margin="6,185,0,0" VerticalAlignment="Top" Grid.Row="1" FontSize="16" />
        <TextBox x:Name="TB_DX_Name" HorizontalAlignment="Left" Height="28" Margin="101,189,0,0" TextWrapping="NoWrap" VerticalAlignment="Top" Width="270" MaxLength="30" Grid.Row="1" Text="{Binding FName, RelativeSource={RelativeSource AncestorType={x:Type Window}, Mode=FindAncestor}}" IsEnabled="True" FontSize="16" TabIndex="15" TextChanged="TB_DX_Name_TextChanged" />
        <Label x:Name="L_CountryLabel" Content="Country" HorizontalAlignment="Left" Margin="378,185,0,0" VerticalAlignment="Top" Grid.Row="1" FontSize="16" Visibility="Visible" />
        <Image x:Name="Img_CountryFlag" HorizontalAlignment="Left" Margin="414,193,0,0" VerticalAlignment="Top" Grid.Row="1" Width="30" Height="20" Stretch="Uniform" Visibility="Collapsed" ToolTip="{Binding Country, RelativeSource={RelativeSource AncestorType={x:Type Window}, Mode=FindAncestor}}" />
        <TextBox x:Name="TB_DXCC" HorizontalAlignment="Left" Height="28" Margin="449,189,0,0" TextWrapping="NoWrap" VerticalAlignment="Top" Width="188" MaxLength="25" Grid.Row="1" Text="{Binding Country, RelativeSource={RelativeSource AncestorType={x:Type Window}, Mode=FindAncestor}}" IsEnabled="True" IsReadOnly="True" FontSize="16" TabIndex="16" />
        <Label Content="State" HorizontalAlignment="Left" Margin="642,185,0,0" VerticalAlignment="Top" Grid.Row="1" FontSize="16" />
        <TextBox x:Name="TB_State" HorizontalAlignment="Left" Height="28" Margin="689,189,0,0" TextWrapping="NoWrap" VerticalAlignment="Top" Width="40" CharacterCasing="Upper" MaxLength="3" Grid.Row="1" FontSize="16" TabIndex="17" TextChanged="TB_State_TextChanged" />
        <!-- Orphaned QRZ-photo frame: never populated by any code (Img_QRZPhoto is unreferenced),
             but its opaque #F5F7FA background at ZIndex 20 painted a white box over the map
             placeholder whenever the WebBrowser was hidden. Collapsed so it cannot bleed through. -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Grid.Row="1" Margin="752,94,0,0" Width="160" Height="160" BorderBrush="#7A95A8" BorderThickness="1" Background="#F5F7FA" CornerRadius="4" Panel.ZIndex="20" Visibility="Collapsed">
            <Image x:Name="Img_QRZPhoto" Stretch="UniformToFill" Visibility="Collapsed" ToolTip="QRZ callsign image" />
        </Border>

        <Label Content="DX Locator" HorizontalAlignment="Left" Margin="6,227,0,0" VerticalAlignment="Top" Grid.Row="1" FontSize="16"  ToolTip="Your grid locator" />
        <TextBox x:Name="TB_DXLocator" HorizontalAlignment="Left" Margin="101,231,0,0" Grid.Row="1" TextWrapping="NoWrap" VerticalAlignment="Top" CharacterCasing="Upper" Width="90" Height="28" FontSize="16" MaxLength="8" TabIndex="18"/>
        <Label Content="Comment" HorizontalAlignment="Left" Margin="210,227,0,0" VerticalAlignment="Top" Grid.Row="1" FontSize="16" ToolTip="Free text comments"/>
        <TextBox x:Name="TB_Comment" HorizontalAlignment="Left" Height="28" Margin="295,231,0,0" TextWrapping="NoWrap" VerticalAlignment="Top" Width="400" Grid.Row="1" Text="{Binding Default.Comment, Source={StaticResource Settings}}" FontSize="16" MaxLength="65" TabIndex="19"/>
        <Image x:Name="LockComment_Btn" ToolTip="Lock/Unlock Comment" HorizontalAlignment="Left" Height="22" Margin="704,235,0,0" VerticalAlignment="Top" Width="20" Source="Images/lock.png" Stretch="None" MouseUp="LockComment_Btn_MouseUp" Grid.Row="1" Cursor="Hand" />
        <!--<ListBox ItemsSource="{Binding}" ItemTemplate="{StaticResource MyDataTemplate}"
             HorizontalContentAlignment="Stretch" Grid.Row="3"/>-->
        <Rectangle Grid.Row="1" Fill="Gainsboro" HorizontalAlignment="Left" VerticalAlignment="Top" Width="736" Height="53" Margin="0,272,0,0" />
        <local:MatrixControl x:Name="MatrixC" HorizontalAlignment="Left" Margin="4,272,0,0" Grid.Row="1" VerticalAlignment="Top" Visibility="Visible"/>
        <DataGrid x:Name="QSODataGrid" ItemsSource="{Binding}" AutoGenerateColumns="False" AlternationCount="2" AlternatingRowBackground="Gainsboro" CanUserAddRows="False" Grid.Row="2" PreviewKeyDown="QSODataGrid_PreviewKeyDown" PreviewMouseRightButtonDown="QSODataGrid_PreviewMouseRightButtonDown" PreviewMouseLeftButtonDown="QSODataGrid_PreviewMouseLeftButtonDown" FontSize="16" ColumnDisplayIndexChanged="QSODataGrid_ColumnDisplayIndexChanged" Drop="QSODataGrid_Drop" AllowDrop="True" Margin="0,0,6,0" BorderBrush="#1565C0" BorderThickness="3" VerticalGridLinesBrush="#888888" HorizontalGridLinesBrush="#888888" Padding="0,0,0,0">
            <DataGrid.Resources>
                <!-- Keep the selected row blue even when the grid loses focus (e.g. while the right-click
                     context menu is open), so the user clearly sees which row the menu refers to. -->
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{x:Static SystemColors.HighlightColor}"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{x:Static SystemColors.HighlightTextColor}"/>
            </DataGrid.Resources>
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="BorderBrush" Value="#1565C0"/>
                    <Setter Property="BorderThickness" Value="0,0,1,3"/>
                    <Setter Property="Padding" Value="5,3,5,3"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="Background" Value="#DEB887"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.RowHeaderStyle>
                <Style TargetType="DataGridRowHeader">
                    <Setter Property="BorderBrush" Value="#1565C0"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                </Style>
            </DataGrid.RowHeaderStyle>
            <!--<DataGrid.ContextMenu>
                <ContextMenu >
                    <MenuItem Header="Delete" Click="MenuItem_Click" />
                </ContextMenu>
            </DataGrid.ContextMenu>-->
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Id" IsReadOnly="True" Visibility="Hidden">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding id}"  HorizontalAlignment="Center" Padding="5,0,5,0"  />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Date" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Date, Converter={StaticResource QsoDateDisplayConverter}}"  HorizontalAlignment="Center" Padding="5,0,5,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Time" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Time, Converter={StaticResource QsoTimeDisplayConverter}}"  HorizontalAlignment="Center" Padding="5,0,5,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Callsign" IsReadOnly="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DXCall}" HorizontalAlignment="Center" Padding="5,0,5,0" FontWeight="Bold" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Name" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" HorizontalAlignment="Center" Padding="5,0,5,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Country" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Country}" HorizontalAlignment="Center" Padding="5,0,5,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Frequency" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Freq}" HorizontalAlignment="Center" Padding="5,0,5,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Band" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Band}" HorizontalAlignment="Center" Padding="5,0,5,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="RST-R" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RST_RCVD}" HorizontalAlignment="Center" Padding="5,0,5,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="RST-S" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RST_SENT}" HorizontalAlignment="Center" Padding="5,0,5,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Mode" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Mode}" HorizontalAlignment="Center" Padding="5,0,5,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Exchange" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SRX}" HorizontalAlignment="Center" Padding="5,0,5,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Comment" IsReadOnly="True" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Comment}" HorizontalAlignment="Center" Padding="5,0,5,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- eQSL queue alert: a red "!" badge overlaid on the log table's top-left header corner.
             Hidden unless there are QSOs waiting to be sent to eQSL; click opens the queue window. -->
        <Border x:Name="EqslQueueBadge" Grid.Row="2" HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="5,5,0,0" Width="22" Height="22" CornerRadius="11" Background="#D32F2F"
                BorderBrush="White" BorderThickness="1.5" Panel.ZIndex="30" Cursor="Hand"
                Visibility="Collapsed" MouseLeftButtonUp="EqslQueueBadge_MouseLeftButtonUp"
                ToolTip="QSOs waiting for eQSL — click to review">
            <TextBlock Text="!" Foreground="White" FontWeight="Bold" FontSize="15"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <ToolsUserControls:MapUserControl x:Name="MapControl" HorizontalAlignment="Stretch" Height="325" Margin="736,0,6,0" Grid.Row="1" VerticalAlignment="Top"/>
        <Border x:Name="MapDisabledPanel" HorizontalAlignment="Stretch" Height="{Binding Height, ElementName=MapControl}" Margin="736,0,6,0" Grid.Row="1" VerticalAlignment="Top" Background="{Binding Fill, ElementName=MainFormBackgroundRect}" Panel.ZIndex="21" Visibility="Collapsed"/>
        <Border HorizontalAlignment="Stretch" Height="325" Margin="736,0,6,0" Grid.Row="1" VerticalAlignment="Top" Background="{Binding Fill, ElementName=MainFormBackgroundRect}" Panel.ZIndex="20" Visibility="Collapsed" x:Name="CustomGraphicsBorder">
            <Image x:Name="Img_CustomGraphics" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform"/>
        </Border>
        <Border HorizontalAlignment="Stretch" Height="325" Margin="736,0,6,0" Grid.Row="1" VerticalAlignment="Top" Background="{Binding Fill, ElementName=MainFormBackgroundRect}" Panel.ZIndex="20" Visibility="Collapsed" x:Name="QRZGraphicsBorder">
            <Image x:Name="Img_QRZGraphics" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform"/>
        </Border>
        <Border HorizontalAlignment="Stretch" Height="325" Margin="736,0,6,0" Grid.Row="1" VerticalAlignment="Top" Background="#4A90E2" Panel.ZIndex="20" Visibility="Collapsed" x:Name="CompassBorder">
            <Grid>
                <Viewbox Width="280" Height="280" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Canvas Width="100" Height="100">
                        <!-- Compass ring background -->
                        <Ellipse Width="100" Height="100" Canvas.Left="0" Canvas.Top="0" StrokeThickness="2">
                            <Ellipse.Stroke>
                                <SolidColorBrush Color="#25464a"/>
                            </Ellipse.Stroke>
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#FFFCFC" Offset="0"/>
                                    <GradientStop Color="#DCE4EC" Offset="0.7"/>
                                    <GradientStop Color="#C8D4E0" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Inner compass face -->
                        <Ellipse Width="78" Height="78" Canvas.Left="11" Canvas.Top="11" StrokeThickness="2">
                            <Ellipse.Stroke>
                                <SolidColorBrush Color="#b9b37e"/>
                            </Ellipse.Stroke>
                            <Ellipse.Fill>
                                <SolidColorBrush Color="#efe6a0"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- Cardinal direction markers (N, E, S, W) -->
                        <TextBlock Text="N" FontSize="11" FontWeight="Bold" Foreground="#134346" Canvas.Left="46" Canvas.Top="6" FontFamily="Segoe UI"/>
                        <TextBlock Text="E" FontSize="11" FontWeight="Bold" Foreground="#134346" Canvas.Left="82" Canvas.Top="46" FontFamily="Segoe UI"/>
                        <TextBlock Text="S" FontSize="11" FontWeight="Bold" Foreground="#134346" Canvas.Left="46" Canvas.Top="82" FontFamily="Segoe UI"/>
                        <TextBlock Text="W" FontSize="11" FontWeight="Bold" Foreground="#134346" Canvas.Left="8" Canvas.Top="46" FontFamily="Segoe UI"/>

                        <!-- Compass needle (rotates based on azimuth) -->
                        <Canvas x:Name="CompassNeedle" Width="100" Height="100" RenderTransformOrigin="0.5,0.5">
                            <Canvas.RenderTransform>
                                <RotateTransform x:Name="CompassNeedleRotation" Angle="0"/>
                            </Canvas.RenderTransform>
                            <!-- North pointer (red) -->
                            <Polygon Points="50,12 58,50 42,50" StrokeThickness="1.2">
                                <Polygon.Fill>
                                    <SolidColorBrush Color="#d10f20"/>
                                </Polygon.Fill>
                                <Polygon.Stroke>
                                    <SolidColorBrush Color="#7b0d18"/>
                                </Polygon.Stroke>
                            </Polygon>
                            <!-- South pointer (blue/green) -->
                            <Polygon Points="50,88 58,50 42,50" StrokeThickness="1.2">
                                <Polygon.Fill>
                                    <SolidColorBrush Color="#197a74"/>
                                </Polygon.Fill>
                                <Polygon.Stroke>
                                    <SolidColorBrush Color="#0f4e4a"/>
                                </Polygon.Stroke>
                            </Polygon>
                        </Canvas>

                        <!-- Center pivot -->
                        <Ellipse Width="9" Height="9" Canvas.Left="45.5" Canvas.Top="45.5" StrokeThickness="1.2">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="#e9e4b9"/>
                            </Ellipse.Fill>
                            <Ellipse.Stroke>
                                <SolidColorBrush Color="#6f6a4d"/>
                            </Ellipse.Stroke>
                        </Ellipse>
                    </Canvas>
                </Viewbox>

                <!-- Azimuth text display in top-left corner -->
                <Border Background="White" BorderBrush="#aaa" BorderThickness="1" CornerRadius="3" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,5,0,0">
                    <TextBlock x:Name="CompassAzimuthText" Text="AZ 0°" FontSize="14" FontWeight="Bold" Foreground="#18393c" FontFamily="Segoe UI"/>
                </Border>
            </Grid>
        </Border>

        <TextBlock HorizontalAlignment="Left" Margin="12,55,0,0" VerticalAlignment="Top" Grid.Row="1" Width="70" Height="38" FontSize="15" ToolTip="Your Personal Callsign" TextAlignment="Left" LineHeight="14" LineStackingStrategy="BlockLineHeight">
            <Run Text="Operator" FontWeight="Bold" />
            <LineBreak />
            <Run Text="Callsign" />
        </TextBlock>
        <TextBox Text="{Binding Default.Operator, Source={StaticResource Settings}}" x:Name="TB_Operator" HorizontalAlignment="Left" Height="28" Margin="85,54,0,0" TextWrapping="NoWrap" VerticalAlignment="Top" Width="99" CharacterCasing="Upper" Grid.Row="1"  TextChanged="TB_MyCallsign_TextChanged" PreviewKeyDown="PreventSpaceInCallsign" FontSize="16" MaxLength="14" TabIndex="4"/>
    </Grid>

</Window>
