<UserControl x:Class="HolyLogger.OptionsUserControls.EqslServiceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:HolyLogger.OptionsUserControls"
             mc:Ignorable="d" Height="520" Width="660">
    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <CheckBox x:Name="CB_AutoUpload" Grid.Row="0" Content="Automatically upload each QSO to eQSL"
                  HorizontalAlignment="Left" Margin="2,6,0,0" VerticalAlignment="Top" FontSize="15"
                  Checked="CB_AutoUpload_Changed" Unchecked="CB_AutoUpload_Changed"/>

        <TextBlock Grid.Row="1" Margin="2,12,0,8" TextWrapping="Wrap" FontSize="12" Foreground="#555555"
                   Text="One eQSL account per station callsign. The Station Callsign column is filled in automatically from the callsigns you log under (set on the main screen). Enter the eQSL user name and password for each callsign you want to upload. A QSO is only sent to the account of the callsign it was logged under."/>

        <DataGrid x:Name="DG_Accounts" Grid.Row="2" Margin="2,0,2,0"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="All" SelectionMode="Single"
                  SelectionUnit="FullRow" FontSize="14"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  CellEditEnding="DG_Accounts_CellEditEnding">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Station Callsign" Binding="{Binding Callsign}" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn Header="eQSL User Name" Binding="{Binding Username}" Width="*"/>
                <DataGridTextColumn Header="Password" Binding="{Binding Password}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,2,4">
            <Button x:Name="RemoveBtn" Content="Remove selected" Width="150" FontSize="15"
                    Margin="0,0,10,0" Click="RemoveBtn_Click"/>
            <Button x:Name="TestConnectionBtn" Content="Test Connection (selected)" Width="200"
                    FontSize="15" Click="TestConnectionBtn_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
