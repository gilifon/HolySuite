<UserControl x:Class="HolyLogger.OptionsUserControls.EqslServiceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:HolyLogger.OptionsUserControls"
             mc:Ignorable="d" Height="680" Width="660">
    <UserControl.Resources>
        <local:PasswordMaskConverter x:Key="PwMask"/>
    </UserControl.Resources>
    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Description -->
        <TextBlock Grid.Row="0" Margin="2,6,0,8" TextWrapping="Wrap" FontSize="12" Foreground="#555555"
                   Text="Add a row for each callsign whose QSOs you want uploaded to eQSL, with its eQSL user name and password. Only callsigns listed here are uploaded — if a callsign is not in this table, its QSOs are never sent to eQSL."/>

        <!-- Add row + Show passwords -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="2,0,0,6" VerticalAlignment="Center">
            <Button x:Name="AddBtn" Content="Add row" Width="100" FontSize="14" Padding="8,3,8,3" Click="AddBtn_Click"/>
            <CheckBox x:Name="CB_ShowPasswords" VerticalAlignment="Center" Margin="16,0,0,0"
                      ToolTip="Show / hide the passwords" Checked="CB_ShowPasswords_Changed" Unchecked="CB_ShowPasswords_Changed">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Fill="#444444" Data="M12,5 C5,5 1.7,11 1,12 C1.7,13 5,19 12,19 C19,19 22.3,13 23,12 C22.3,11 19,5 12,5 Z M12,16 C9.8,16 8,14.2 8,12 C8,9.8 9.8,8 12,8 C14.2,8 16,9.8 16,12 C16,14.2 14.2,16 12,16 Z M12,10 C10.9,10 10,10.9 10,12 C10,13.1 10.9,14 12,14 C13.1,14 14,13.1 14,12 C14,10.9 13.1,10 12,10 Z"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Show passwords" Margin="6,0,0,0" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </CheckBox>
        </StackPanel>

        <!-- Accounts table -->
        <DataGrid x:Name="DG_Accounts" Grid.Row="2" Margin="2,0,2,0"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="All" SelectionMode="Single"
                  SelectionUnit="FullRow" FontSize="14" Height="148"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  CellEditEnding="DG_Accounts_CellEditEnding">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Station Callsign" Binding="{Binding Callsign, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="eQSL User Name" Binding="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTemplateColumn Header="Password" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Password, Converter={StaticResource PwMask}}" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <Grid>
                                <PasswordBox x:Name="EditPb" BorderThickness="0" VerticalContentAlignment="Center"
                                             Loaded="EditPassword_Loaded" PasswordChanged="EditPassword_Changed"/>
                                <TextBox x:Name="EditTb" BorderThickness="0" VerticalContentAlignment="Center"
                                         Loaded="EditText_Loaded"
                                         Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Remove / Test buttons (right-aligned, matching QRZ style) -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,2,4">
            <Button x:Name="RemoveBtn" Content="Remove selected" Width="150" FontSize="15"
                    Margin="0,0,10,0" Click="RemoveBtn_Click"/>
            <Button x:Name="TestConnectionBtn" Content="Test Connection (selected)" Width="200"
                    FontSize="15" Click="TestConnectionBtn_Click"/>
        </StackPanel>

        <!-- Auto-upload checkbox (same position as QRZ) -->
        <CheckBox x:Name="CB_AutoUpload" Grid.Row="4" Content="Automatically upload each QSO to eQSL"
                  HorizontalAlignment="Left" Margin="2,8,0,0" VerticalAlignment="Top" FontSize="15"
                  Checked="CB_AutoUpload_Changed" Unchecked="CB_AutoUpload_Changed"/>

        <!-- Clear Queue button (below checkbox, same as QRZ) -->
        <Button x:Name="ClearQueueBtn" Grid.Row="5" Content="Clear eQSL Queue" Width="160" FontSize="15"
                HorizontalAlignment="Left" Margin="2,10,0,0" Click="ClearQueueBtn_Click"/>

        <!-- Separator -->
        <Border Grid.Row="6" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,14,0,0"/>

        <!-- Upload-on-exit section -->
        <TextBlock Grid.Row="7" Text="Upload Queue on Exit" FontSize="14" FontWeight="SemiBold"
                   Margin="2,10,0,4"/>
        <TextBlock Grid.Row="8" Margin="2,0,8,8" TextWrapping="Wrap" FontSize="12" Foreground="#555555"
                   Text="When you close HolyLogger, the pending eQSL queue can be uploaded automatically — only when an internet connection is available. Choose how this should behave."/>
        <StackPanel Grid.Row="9" Orientation="Horizontal" Margin="2,2,0,8" VerticalAlignment="Center">
            <TextBlock Text="On exit:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="CB_OnExit" Width="320" FontSize="13"
                      SelectionChanged="CB_OnExit_Changed">
                <ComboBoxItem Content="Do not upload on exit"/>
                <ComboBoxItem Content="Ask me before uploading on exit"/>
                <ComboBoxItem Content="Always upload on exit (no prompt)"/>
            </ComboBox>
        </StackPanel>
    </Grid>
</UserControl>
