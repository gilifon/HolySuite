<UserControl x:Class="HolyLogger.OptionsUserControls.LotwControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:HolyLogger.OptionsUserControls"
             mc:Ignorable="d" Height="700" Width="660">
    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ARRL Logbook of the World (LoTW)" FontSize="17" FontWeight="Bold"
                   Margin="2,4,0,4"/>

        <TextBlock Grid.Row="1" Margin="2,0,8,10" TextWrapping="Wrap" FontSize="12" Foreground="#555555"
                   Text="Upload pending QSOs to LoTW by signing them with your local TQSL program. Use Tools → Upload Queue to LoTW from the main window to run the upload. TQSL must be installed and you must have a valid callsign certificate."/>

        <Label Grid.Row="2" Content="TQSL Path" HorizontalAlignment="Left" Margin="0,0,0,0"
               VerticalAlignment="Top" FontSize="14"/>
        <Grid Grid.Row="2" Margin="160,2,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="TB_TqslPath" Height="26" TextWrapping="NoWrap"
                     VerticalAlignment="Top" FontSize="13" VerticalContentAlignment="Center"
                     TextChanged="TB_TqslPath_TextChanged"/>
            <Button Grid.Column="1" x:Name="BrowseBtn" Content="Browse…" Width="72" Margin="6,0,0,0"
                    FontSize="13" Click="BrowseBtn_Click"/>
        </Grid>

        <Label Grid.Row="3" Content="Station Location" HorizontalAlignment="Left" Margin="0,8,0,0"
               VerticalAlignment="Top" FontSize="14"/>
        <TextBox Grid.Row="3" x:Name="TB_StationLocation" HorizontalAlignment="Left" Height="26"
                 Margin="160,10,0,0" TextWrapping="NoWrap" VerticalAlignment="Top" Width="300"
                 FontSize="13" VerticalContentAlignment="Center"
                 TextChanged="TB_StationLocation_TextChanged"/>

        <TextBlock Grid.Row="4" Margin="160,2,8,0" TextWrapping="Wrap" FontSize="11" Foreground="#888888"
                   Text="Must match exactly the station location name defined in TQSL (case-sensitive)."/>

        <Label Grid.Row="5" Content="Certificate Password" HorizontalAlignment="Left" Margin="0,8,0,0"
               VerticalAlignment="Top" FontSize="14"/>
        <PasswordBox Grid.Row="5" x:Name="PB_Password" HorizontalAlignment="Left" Height="26"
                     Margin="160,10,0,0" VerticalAlignment="Top" Width="220" FontSize="13"
                     VerticalContentAlignment="Center" PasswordChanged="PB_Password_Changed"/>

        <TextBlock Grid.Row="6" Margin="160,2,8,0" TextWrapping="Wrap" FontSize="11" Foreground="#888888"
                   Text="Leave blank if your callsign certificate has no password."/>

        <!-- Separator -->
        <Border Grid.Row="7" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,14,0,0"/>

        <!-- Web Login section -->
        <TextBlock Grid.Row="8" Text="LoTW Web Login" FontSize="14" FontWeight="SemiBold"
                   Margin="2,10,0,4"/>
        <TextBlock Grid.Row="9" Margin="2,0,8,8" TextWrapping="Wrap" FontSize="12" Foreground="#555555"
                   Text="Required for downloading confirmed QSOs from LoTW (e.g. to fill missing Band / Mode in your log). This is your LoTW website login — not the TQSL certificate password. Uploading does not use this login; TQSL uploads with your callsign certificate."/>

        <Label Grid.Row="10" Content="LoTW Username" HorizontalAlignment="Left" Margin="0,4,0,0"
               VerticalAlignment="Top" FontSize="14"/>
        <TextBox Grid.Row="10" x:Name="TB_WebUser" HorizontalAlignment="Left" Height="26"
                 Margin="160,6,0,0" TextWrapping="NoWrap" VerticalAlignment="Top" Width="220"
                 FontSize="13" VerticalContentAlignment="Center"
                 TextChanged="TB_WebUser_TextChanged"/>

        <Label Grid.Row="11" Content="LoTW Password" HorizontalAlignment="Left" Margin="0,8,0,0"
               VerticalAlignment="Top" FontSize="14"/>
        <PasswordBox Grid.Row="11" x:Name="PB_WebPassword" HorizontalAlignment="Left" Height="26"
                     Margin="160,10,0,0" VerticalAlignment="Top" Width="220" FontSize="13"
                     VerticalContentAlignment="Center" PasswordChanged="PB_WebPassword_Changed"/>

        <!-- Separator -->
        <Border Grid.Row="12" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,14,0,0"/>

        <!-- Reset pending from date section -->
        <TextBlock Grid.Row="13" Text="Reset Upload Queue" FontSize="14" FontWeight="SemiBold"
                   Margin="2,10,0,4"/>

        <TextBlock Grid.Row="14" Margin="2,0,8,8" TextWrapping="Wrap" FontSize="12" Foreground="#555555"
                   Text="Mark QSOs from a chosen date onwards as pending so they will be included in the next LoTW upload. LoTW ignores duplicates automatically, so it is safe to re-upload QSOs already in LoTW."/>

        <StackPanel Grid.Row="15" Orientation="Horizontal" Margin="2,4,0,0" VerticalAlignment="Center">
            <TextBlock Text="From date:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <DatePicker x:Name="DP_FromDate" FontSize="13" Width="140" VerticalAlignment="Center"/>
            <Button x:Name="ResetFromDateBtn" Content="Mark as Pending" Width="140" FontSize="13"
                    Margin="12,0,0,0" Padding="8,4,8,4" Click="ResetFromDateBtn_Click"/>
            <Button x:Name="ClearQueueBtn" Content="Clear Queue" Width="120" FontSize="13"
                    Margin="12,0,0,0" Padding="8,4,8,4" Click="ClearQueueBtn_Click"/>
            <Button x:Name="TestBtn" Content="Test TQSL" Width="100" FontSize="13"
                    Margin="20,0,0,0" Padding="8,4,8,4" Click="TestBtn_Click"/>
        </StackPanel>

        <Border x:Name="StatusBadge" Grid.Row="16" Background="#E6F4EA" BorderBrush="#34A853"
                BorderThickness="1" CornerRadius="3" Padding="8,4,8,4"
                Margin="2,10,8,0" HorizontalAlignment="Left" Visibility="Collapsed">
            <TextBlock x:Name="StatusText" Foreground="#1E7E34" FontSize="13" FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Separator -->
        <Border Grid.Row="17" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,16,0,0"/>

        <!-- Upload-on-exit section -->
        <TextBlock Grid.Row="18" Text="Upload Queue on Exit" FontSize="14" FontWeight="SemiBold"
                   Margin="2,10,0,4"/>
        <TextBlock Grid.Row="19" Margin="2,0,8,8" TextWrapping="Wrap" FontSize="12" Foreground="#555555"
                   Text="When you close HolyLogger, the pending LoTW queue can be signed and uploaded automatically — only when an internet connection is available. Choose how this should behave."/>
        <StackPanel Grid.Row="20" Orientation="Horizontal" Margin="2,2,0,8" VerticalAlignment="Center">
            <TextBlock Text="On exit:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="CB_UploadOnExit" Width="320" FontSize="13"
                      SelectionChanged="CB_UploadOnExit_SelectionChanged">
                <ComboBoxItem Content="Do not upload on exit"/>
                <ComboBoxItem Content="Ask me before uploading on exit"/>
                <ComboBoxItem Content="Always upload on exit (no prompt)"/>
            </ComboBox>
        </StackPanel>
    </Grid>
</UserControl>
