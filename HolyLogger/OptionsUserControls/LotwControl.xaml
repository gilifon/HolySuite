<UserControl x:Class="HolyLogger.OptionsUserControls.LotwControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:HolyLogger.OptionsUserControls"
             mc:Ignorable="d" Height="730" Width="690">
    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ARRL Logbook of the World (LoTW)" FontSize="17" FontWeight="Bold"
                   Margin="2,2,0,2"/>

        <TextBlock Grid.Row="1" Margin="2,0,8,6" TextWrapping="Wrap" FontSize="12" Foreground="#555555"
                   Text="QSOs are signed and uploaded with your local TQSL program. TQSL must be installed with a valid callsign certificate. Use Tools → Upload Queue to LoTW from the main window to run the upload."/>

        <!-- TQSL path -->
        <Grid Grid.Row="2" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="TQSL Path" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="14"/>
            <TextBox Grid.Column="1" x:Name="TB_TqslPath" Height="26" TextWrapping="NoWrap"
                     VerticalAlignment="Center" FontSize="13" VerticalContentAlignment="Center"
                     TextChanged="TB_TqslPath_TextChanged"/>
            <Button Grid.Column="2" x:Name="BrowseBtn" Content="Browse…" Width="72" Margin="6,0,0,0"
                    FontSize="13" Click="BrowseBtn_Click"/>
        </Grid>

        <!-- Certificate password -->
        <Grid Grid.Row="3" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="Certificate Password" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="14"/>
            <PasswordBox Grid.Column="1" x:Name="PB_Password" Height="26" Width="220"
                         VerticalAlignment="Center" FontSize="13" VerticalContentAlignment="Center"
                         PasswordChanged="PB_Password_Changed"/>
            <TextBlock Grid.Column="2" Margin="10,0,8,0" TextWrapping="Wrap" FontSize="11" Foreground="#888888"
                       VerticalAlignment="Center" Text="Blank if your certificate has no password."/>
        </Grid>

        <!-- Separator -->
        <Border Grid.Row="4" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,10,0,0"/>

        <!-- Station location (auto-selected) -->
        <TextBlock Grid.Row="5" Text="Station Location — selected automatically by callsign" FontSize="14"
                   FontWeight="SemiBold" Margin="2,10,0,2"/>
        <TextBlock Grid.Row="6" x:Name="TB_LocationsHelp" Margin="2,0,8,6" TextWrapping="Wrap" FontSize="12" Foreground="#555555"
                   Text="HolyLogger reads your TQSL station locations (read-only) and signs each callsign with its own location. Nothing to type — just keep your locations set up in TQSL."/>

        <!-- Current-callsign resolution line -->
        <Border Grid.Row="7" Background="#F4F8FC" BorderBrush="#CBD9E6" BorderThickness="1" CornerRadius="3"
                Padding="8,5,8,5" Margin="2,0,8,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Current Station Callsign: " FontSize="13" VerticalAlignment="Center"/>
                <TextBlock x:Name="TB_CurrentCallsign" Text="—" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="TB_ResolvedLocation" Text="" FontSize="13" Margin="10,0,0,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="CB_AmbiguousPick" Width="200" FontSize="13" Margin="8,0,0,0"
                          VerticalAlignment="Center" Visibility="Collapsed"
                          SelectionChanged="CB_AmbiguousPick_SelectionChanged"/>
            </StackPanel>
        </Border>

        <!-- Read-only table of TQSL station locations -->
        <DataGrid Grid.Row="8" x:Name="DG_Locations" Margin="2,0,8,0" Height="118"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="All" SelectionMode="Single"
                  FontSize="13" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                            <Setter Property="Background" Value="#CFEFCF"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Callsign" Binding="{Binding Callsign}" Width="1.2*"/>
                <DataGridTextColumn Header="Station Location (TQSL)" Binding="{Binding Location}" Width="2*"/>
                <DataGridTextColumn Header="Grid" Binding="{Binding Grid}" Width="1*"/>
                <DataGridTextColumn Header="DXCC" Binding="{Binding Dxcc}" Width="0.8*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Refresh from TQSL -->
        <Grid Grid.Row="9" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Margin="2,0,8,0" TextWrapping="Wrap" FontSize="11" Foreground="#888888"
                       VerticalAlignment="Center"
                       Text="A callsign with no station location above has no LoTW certificate — its QSOs cannot be uploaded until you create one in TQSL."/>
            <Button Grid.Column="1" x:Name="RefreshLocationsBtn" Content="Refresh from TQSL" Width="130"
                    FontSize="12" Padding="6,3,6,3" Click="RefreshLocationsBtn_Click"/>
        </Grid>

        <!-- Separator -->
        <Border Grid.Row="10" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,10,0,0"/>

        <!-- Web Login section -->
        <TextBlock Grid.Row="11" Text="LoTW Web Login" FontSize="14" FontWeight="SemiBold"
                   Margin="2,8,0,2"/>
        <TextBlock Grid.Row="12" Margin="2,0,8,4" TextWrapping="Wrap" FontSize="12" Foreground="#555555"
                   Text="Required only for downloading confirmed QSOs from LoTW (to fill missing Band / Mode). This is your LoTW website login — not the TQSL certificate password. Uploads do not use this login."/>

        <Grid Grid.Row="13" Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Content="LoTW Username" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="14"/>
            <TextBox Grid.Column="1" x:Name="TB_WebUser" Height="26" Width="200" TextWrapping="NoWrap"
                     VerticalAlignment="Center" FontSize="13" VerticalContentAlignment="Center"
                     TextChanged="TB_WebUser_TextChanged"/>
            <Label Grid.Column="2" Content="Password" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="14" Margin="16,0,0,0"/>
            <PasswordBox Grid.Column="3" x:Name="PB_WebPassword" Height="26" Width="200"
                         VerticalAlignment="Center" FontSize="13" VerticalContentAlignment="Center"
                         PasswordChanged="PB_WebPassword_Changed"/>
        </Grid>

        <!-- Separator -->
        <Border Grid.Row="14" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,10,0,0"/>

        <!-- Reset pending from date section -->
        <TextBlock Grid.Row="15" Text="Reset Upload Queue" FontSize="14" FontWeight="SemiBold"
                   Margin="2,8,0,2"/>
        <TextBlock Grid.Row="16" Margin="2,0,8,4" TextWrapping="Wrap" FontSize="12" Foreground="#555555"
                   Text="Mark QSOs from a chosen date onwards as pending so they are included in the next upload. LoTW ignores duplicates, so re-uploading is safe."/>
        <StackPanel Grid.Row="17" Orientation="Horizontal" Margin="2,2,0,0" VerticalAlignment="Center">
            <TextBlock Text="From date:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <DatePicker x:Name="DP_FromDate" FontSize="13" Width="140" VerticalAlignment="Center"/>
            <Button x:Name="ResetFromDateBtn" Content="Mark as Pending" Width="140" FontSize="13"
                    Margin="12,0,0,0" Padding="8,4,8,4" Click="ResetFromDateBtn_Click"/>
            <Button x:Name="ClearQueueBtn" Content="Clear Queue" Width="120" FontSize="13"
                    Margin="12,0,0,0" Padding="8,4,8,4" Click="ClearQueueBtn_Click"/>
            <Button x:Name="TestBtn" Content="Test TQSL" Width="100" FontSize="13"
                    Margin="20,0,0,0" Padding="8,4,8,4" Click="TestBtn_Click"/>
        </StackPanel>

        <Border x:Name="StatusBadge" Grid.Row="18" Background="#E6F4EA" BorderBrush="#34A853"
                BorderThickness="1" CornerRadius="3" Padding="8,4,8,4"
                Margin="2,8,8,0" HorizontalAlignment="Left" Visibility="Collapsed">
            <TextBlock x:Name="StatusText" Foreground="#1E7E34" FontSize="13" FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Separator -->
        <Border Grid.Row="19" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,10,0,0"/>

        <!-- Upload-on-exit section -->
        <TextBlock Grid.Row="20" Text="Upload Queue on Exit" FontSize="14" FontWeight="SemiBold"
                   Margin="2,8,0,2"/>
        <StackPanel Grid.Row="21" Orientation="Horizontal" Margin="2,2,0,0" VerticalAlignment="Center">
            <TextBlock Text="On exit:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox x:Name="CB_UploadOnExit" Width="320" FontSize="13"
                      SelectionChanged="CB_UploadOnExit_SelectionChanged">
                <ComboBoxItem Content="Do not upload on exit"/>
                <ComboBoxItem Content="Ask me before uploading on exit"/>
                <ComboBoxItem Content="Always upload on exit (no prompt)"/>
            </ComboBox>
        </StackPanel>
    </Grid>
</UserControl>
