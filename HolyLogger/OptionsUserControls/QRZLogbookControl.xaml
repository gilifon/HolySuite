<UserControl x:Class="HolyLogger.OptionsUserControls.QRZLogbookControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:HolyLogger.OptionsUserControls"
             mc:Ignorable="d" Height="300" Width="660">
    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="QRZ.com Logbook — real-time QSO upload" FontSize="17" FontWeight="Bold"
                   Margin="2,4,0,4"/>

        <TextBlock Grid.Row="1" Margin="2,0,8,10" TextWrapping="Wrap" FontSize="12" Foreground="#555555"
                   Text="Each QSO you log is uploaded to your QRZ.com online logbook the moment you save it. This requires an active QRZ XML Logbook Data Subscription and your Logbook API Key (found on your QRZ.com logbook settings page)."/>

        <Label Grid.Row="2" Content="Logbook API Key" HorizontalAlignment="Left" Margin="0,0,0,0"
               VerticalAlignment="Top" FontSize="16"/>
        <TextBox Grid.Row="2" x:Name="TB_ApiKey" HorizontalAlignment="Left" Height="26" Margin="150,2,0,0"
                 TextWrapping="NoWrap" VerticalAlignment="Top" Width="300" FontSize="16"
                 VerticalContentAlignment="Center" TextChanged="TB_ApiKey_TextChanged"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="2,10,0,0">
            <Button x:Name="GetKeyBtn" Content="Get My QRZ API Key Automatically" FontSize="14"
                    Padding="10,4,10,4" Click="GetKeyBtn_Click"/>
            <Button x:Name="TestBtn" Content="Test" Width="110" FontSize="14" Margin="14,0,0,0"
                    Padding="10,4,10,4" Click="TestBtn_Click"/>
        </StackPanel>

        <Border Grid.Row="4" x:Name="StatusBadge" Background="#E6F4EA" BorderBrush="#34A853"
                BorderThickness="1" CornerRadius="3" Padding="8,4,8,4" HorizontalAlignment="Left"
                Margin="2,12,0,0" Visibility="Collapsed">
            <TextBlock x:Name="StatusText" Foreground="#1E7E34" FontSize="13" FontWeight="SemiBold"/>
        </Border>

        <CheckBox Grid.Row="5" x:Name="CB_AutoPush"
                  Content="Automatically upload each QSO to QRZ Logbook in real time"
                  HorizontalAlignment="Left" Margin="2,18,0,0" VerticalAlignment="Top" FontSize="15"
                  IsEnabled="False" Checked="CB_AutoPush_Changed" Unchecked="CB_AutoPush_Changed"/>

        <TextBlock Grid.Row="6" x:Name="HintText" Margin="22,4,8,0" TextWrapping="Wrap" FontSize="11"
                   Foreground="#888888"
                   Text="Test your API key first — this option stays disabled until a valid key passes validation."/>
    </Grid>
</UserControl>
