<UserControl x:Class="HolyLogger.OptionsUserControls.UserInterfaceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HolyLogger.OptionsUserControls"
             mc:Ignorable="d" 
             d:DesignHeight="530" d:DesignWidth="380">

    <Grid ShowGridLines="false" HorizontalAlignment="Stretch">
        <CheckBox x:Name="CBX_ShowClusterWindowOption" Content="Show Cluster window" HorizontalAlignment="Left" VerticalAlignment="Top" IsChecked="{Binding Default.ShowClusterWindowOption, Source={StaticResource Settings}, Mode=TwoWay}" FontSize="16"/>
        <CheckBox x:Name="CBX_IsShowMatrix" Content="Show matrix in main window" HorizontalAlignment="Left" VerticalAlignment="Top" IsChecked="{Binding Default.IsShowMatrixControl, Source={StaticResource Settings}, Mode=TwoWay}" FontSize="16" Margin="0,26,0,0"/>
        <CheckBox x:Name="CBX_IsShowAzimuth" Content="Show map" HorizontalAlignment="Left" VerticalAlignment="Top" IsChecked="{Binding Default.IsShowAzimuthControl, Source={StaticResource Settings}, Mode=TwoWay}" FontSize="16" Margin="0,52,0,0"/>
        <CheckBox x:Name="CBX_ShowTitleClock" Content="Show UTC clock in the title" HorizontalAlignment="Left" VerticalAlignment="Top" IsChecked="{Binding Default.ShowTitleClock, Mode=TwoWay, Source={StaticResource Settings}}" FontSize="16" Margin="0,78,0,0" Click="HasChanged_Click"/>
        <CheckBox x:Name="CBX_ShowNetworkFlag" Content="Show the Network connectivity icon" HorizontalAlignment="Left" VerticalAlignment="Top" IsChecked="{Binding Default.ShowNetworkFlag, Mode=TwoWay, Source={StaticResource Settings}}" FontSize="16" Margin="0,104,0,0"/>
        <CheckBox x:Name="CBX_ShowPhotoFromQrz" Content="Show Photo From QRZ" HorizontalAlignment="Left" VerticalAlignment="Top" IsChecked="{Binding Default.ShowPhotoFromQRZ, Mode=TwoWay, Source={StaticResource Settings}}" FontSize="16" Margin="0,130,0,0" Click="HasChanged_Click"/>
        <CheckBox x:Name="CBX_Lock" Content="Lock My Callsign" HorizontalAlignment="Left" VerticalAlignment="Top" IsChecked="{Binding Default.isLocked, Mode=TwoWay, Source={StaticResource Settings}}" FontSize="16" Margin="0,156,0,0"/>
        <CheckBox x:Name="CBX_DisplayLastQSOinGrid" Content="Highlight last QSO" HorizontalAlignment="Left" VerticalAlignment="Top" IsChecked="{Binding Default.DisplayLastQSOinGrid, Source={StaticResource Settings}, Mode=TwoWay}" FontSize="16" Margin="0,182,0,0"/>
        <CheckBox x:Name="CBX_UseDXCCDefaultGrid" Content="Use default grid for DXCC" HorizontalAlignment="Left" VerticalAlignment="Top" IsChecked="{Binding Default.UseDXCCDefaultGrid, Source={StaticResource Settings}, Mode=TwoWay}" FontSize="16" Margin="0,208,0,0"/>
        <CheckBox x:Name="CBX_ShowCallsignDropdown" Content="Show callsign autocomplete dropdown" HorizontalAlignment="Left" VerticalAlignment="Top" IsChecked="{Binding Default.ShowCallsignDropdown, Source={StaticResource Settings}, Mode=TwoWay}" FontSize="16" Margin="0,234,0,0"/>
        <Label Content="Callsign autocomplete # of lines" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,262,0,0" FontSize="16"/>
        <ComboBox x:Name="CB_CallsignSuggestionRows" HorizontalAlignment="Left" VerticalAlignment="Top" Width="90" Height="28" Margin="260,268,0,0" SelectionChanged="CB_CallsignSuggestionRows_SelectionChanged" FontSize="16">
            <ComboBoxItem Content="10"/>
            <ComboBoxItem Content="15"/>
            <ComboBoxItem Content="20"/>
            <ComboBoxItem Content="25"/>
            <ComboBoxItem Content="30"/>
        </ComboBox>
        <Label Content="Auto Fit Radius % Increas by" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,292,0,0" FontSize="16"/>
        <ComboBox x:Name="CB_MapAutoFitMargin" HorizontalAlignment="Left" VerticalAlignment="Top" Width="60" Height="28" Margin="260,298,0,0" SelectionChanged="CB_MapAutoFitMargin_SelectionChanged" FontSize="16">
            <ComboBoxItem Content="0"/>
            <ComboBoxItem Content="5"/>
            <ComboBoxItem Content="10"/>
            <ComboBoxItem Content="15"/>
            <ComboBoxItem Content="20"/>
            <ComboBoxItem Content="25"/>
        </ComboBox>
        <Label Content="DX station distance unit" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,322,0,0" FontSize="16"/>
        <ComboBox x:Name="CB_MapDistanceUnit" HorizontalAlignment="Left" VerticalAlignment="Top" Width="90" Height="28" Margin="260,328,0,0" SelectionChanged="CB_MapDistanceUnit_SelectionChanged" FontSize="16">
            <ComboBoxItem Content="KM"/>
            <ComboBoxItem Content="Miles"/>
        </ComboBox>
        <GroupBox x:Name="groupBox" Header="When 'Enter' is pressed" Height="90" Margin="10,358,10,0" VerticalAlignment="Top" Width="360" FontSize="16">
            <StackPanel>
                <RadioButton x:Name="DoNothing_RB" HorizontalAlignment="Left" Margin="0,8,0,0" VerticalAlignment="Top" Content="Do Nothing" Click="HasChanged_Click" IsChecked="{Binding Default.DoNothing, Mode=TwoWay, Source={StaticResource Settings}}" FontSize="16"/>
                <RadioButton x:Name="AddQSO_RB" HorizontalAlignment="Left" Margin="0,8,0,0" VerticalAlignment="Top" Content="Add QSO" Click="HasChanged_Click" IsChecked="{Binding Default.AddQSOWithEnter, Mode=TwoWay, Source={StaticResource Settings}}" FontSize="16"/>
            </StackPanel>
        </GroupBox>
        <GroupBox Header="Color Theme" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,456,10,0" Width="360" Height="100" FontSize="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="38"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="188"/>
                    <ColumnDefinition Width="162"/>
                </Grid.ColumnDefinitions>

                <Label Content="Main form background" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="14"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Border x:Name="MainFormBackgroundPreview" Width="40" Height="28" VerticalAlignment="Center" BorderBrush="#666" BorderThickness="2" Background="#BDDFFF" Cursor="Hand" MouseLeftButtonDown="MainFormBackgroundPreview_MouseLeftButtonDown" ToolTip="Click to pick a color"/>
                    <Button x:Name="BtnResetMainFormBackground" Content="Reset" Width="46" Height="24" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" Click="BtnResetMainFormBackground_Click"/>
                </StackPanel>

                <Label Content="QSO table header" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontSize="14"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Border x:Name="QsoTableHeaderBackgroundPreview" Width="40" Height="28" VerticalAlignment="Center" BorderBrush="#666" BorderThickness="2" Background="#DEB887" Cursor="Hand" MouseLeftButtonDown="QsoTableHeaderBackgroundPreview_MouseLeftButtonDown" ToolTip="Click to pick a color"/>
                    <Button x:Name="BtnResetQsoTableHeaderBackground" Content="Reset" Width="46" Height="24" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" Click="BtnResetQsoTableHeaderBackground_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        <!--<CheckBox x:Name="CBX_QRZAutoOpen" Content="Auto open QRZ.com page" HorizontalAlignment="Left" VerticalAlignment="Top" IsChecked="{Binding Default.QRZ_auto_open, Source={StaticResource Settings}, Mode=TwoWay}" FontSize="16" Margin="0,156,0,0"/>-->
    </Grid>
</UserControl>
