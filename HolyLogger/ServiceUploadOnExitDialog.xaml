<Window x:Class="HolyLogger.ServiceUploadOnExitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upload on Exit"
        Width="520" Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Upload icon — blue circle with up-arrow -->
        <Ellipse Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                 Width="44" Height="44" Fill="#1565C0"
                 VerticalAlignment="Top" HorizontalAlignment="Left"/>
        <Viewbox Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                 Width="26" Height="26" VerticalAlignment="Top" HorizontalAlignment="Left"
                 Margin="9,9,0,0">
            <Path Fill="White" Stretch="Uniform"
                  Data="M5 20h14v-2H5v2zm0-10h4v6h6v-6h4l-7-7-7 7z"/>
        </Viewbox>

        <!-- QSO count badge -->
        <Border Grid.Row="0" Grid.Column="1"
                Background="#E3F2FD" BorderBrush="#1565C0" BorderThickness="1"
                CornerRadius="5" Padding="14,8" HorizontalAlignment="Left">
            <TextBlock FontSize="18">
                <Run x:Name="CountRun" FontWeight="Bold" Foreground="#1565C0"/>
                <Run x:Name="ServiceRun" Foreground="#1565C0"/>
            </TextBlock>
        </Border>

        <!-- Question -->
        <TextBlock Grid.Row="2" Grid.Column="1"
                   Text="Upload them now before exiting?"
                   FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="YesBtn" Content="Yes — Upload" Width="140" Height="38"
                    FontSize="16" IsDefault="True" Margin="0,0,10,0"
                    Click="YesBtn_Click"/>
            <Button x:Name="NoBtn" Content="No — Exit now" Width="140" Height="38"
                    FontSize="16" Margin="0,0,10,0"
                    Click="NoBtn_Click"/>
            <Button x:Name="CancelBtn" Content="Cancel" Width="100" Height="38"
                    FontSize="16" IsCancel="True"
                    Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
