<Window x:Class="HolyLogger.StationServicesAlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logging Services Check" Width="540" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False" Background="#EEF2F7"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid Margin="20,18,20,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Logging Services — Station Callsign Check"
                       FontSize="15" FontWeight="Bold" Foreground="#1565C0"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Station callsign: " FontSize="13" Foreground="#444444"/>
                <TextBlock x:Name="TB_Callsign" FontSize="13" FontWeight="Bold" Foreground="#1565C0"/>
            </StackPanel>
            <TextBlock x:Name="TB_SubHeader"
                       FontSize="12" Foreground="#B35C00" Margin="0,3,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Service rows (populated in code-behind) -->
        <Border Grid.Row="2" BorderBrush="#1565C0" BorderThickness="1"
                Background="White" CornerRadius="3">
            <StackPanel x:Name="ServicesPanel" Margin="14,10,14,10"/>
        </Border>

        <!-- Close button — IsCancel=True means Escape clicks it automatically -->
        <Button Grid.Row="4" x:Name="Btn_Close" Content="Close"
                Width="110" Height="36" FontSize="15" FontWeight="Bold"
                HorizontalAlignment="Right"
                IsDefault="True" IsCancel="True"
                Click="Btn_Close_Click"/>
    </Grid>
</Window>
