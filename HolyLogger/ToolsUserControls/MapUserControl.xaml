<UserControl x:Class="HolyLogger.ToolsUserControls.MapUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="220" d:DesignWidth="220">
    <Grid>
        <WebBrowser x:Name="MapBrowser" />
        <Border x:Name="PlaceholderPanel" Background="#DCEBF8">
            <Grid Margin="10">
                <!-- Arrow tip at Y=20 in this grid = Y=30 from MapControl top = My Locator textbox center -->
                <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        IsHitTestVisible="False" ClipToBounds="False" Panel.ZIndex="2" Margin="-10">
                    <Polygon Points="-325,30  -307,19  -307,28  85,28  85,32  -307,32  -307,41"
                             Fill="#D7263D" Stroke="#8F1422" StrokeThickness="1.5"/>
                </Canvas>

                <Border Width="250"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,0,0,0"
                        Padding="18,16,18,16"
                        CornerRadius="10"
                        Background="#FFF7E8"
                        BorderBrush="#D7263D"
                        BorderThickness="3"
                        Effect="{x:Null}">
                    <StackPanel>
                        <TextBlock Text="MAP DISABLED"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#A31621"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="PlaceholderText"
                                   Margin="0,10,0,0"
                                   Text="Please set My Locator"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#1E2A36"/>
                        <TextBlock Margin="0,10,0,0"
                                   Text="Enter your locator in the box on the left to enable the map."
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#4B5B68"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
