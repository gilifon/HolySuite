<Window x:Class="HolyLogger.UploadProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uploading on Exit" Width="480" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F6F6F6"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown">
    <Grid Margin="22,18,22,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock x:Name="TitleText" Grid.Row="0"
                   Text="Uploading on Exit…"
                   FontSize="16" FontWeight="SemiBold" Foreground="#1A1A1A"
                   Margin="0,0,0,14"/>

        <!-- Scrollable upload log -->
        <Border Grid.Row="1" BorderBrush="#DADADA" BorderThickness="1"
                CornerRadius="4" Background="White">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto"
                          Padding="10,8,10,8">
                <StackPanel x:Name="LogPanel"/>
            </ScrollViewer>
        </Border>

        <!-- Indeterminate progress bar (hidden when done) -->
        <ProgressBar x:Name="Spinner" Grid.Row="2"
                     IsIndeterminate="True" Height="5" Margin="0,10,0,0"
                     Foreground="#1A73E8" Background="Transparent"/>

        <!-- Summary line (visible when done) -->
        <TextBlock x:Name="SummaryText" Grid.Row="3"
                   Margin="0,12,0,0" FontSize="13" FontWeight="SemiBold"
                   TextWrapping="Wrap" Visibility="Collapsed"/>

        <!-- OK button (visible when done) -->
        <Button x:Name="OkBtn" Grid.Row="4"
                Content="OK" Width="110" Height="34" FontSize="14"
                HorizontalAlignment="Right" Margin="0,12,0,0"
                Background="#1A73E8" Foreground="White" BorderThickness="0"
                IsDefault="True" IsCancel="True"
                Visibility="Collapsed" Click="OkBtn_Click"/>
    </Grid>
</Window>
